# Overflow Docker 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ===== Overflow connections =====
# 多 OneBot 实例：设为此变量后，直接作为 connections 数组写入 overflow.json（与
# https://github.com/MrXiaoM/Overflow/issues/184 及上游 configuration.md 一致）
# 单行示例（compose / shell 注意引号）：
# OVERFLOW_CONNECTIONS_JSON=[{"enable":true,"type":"websocket","host":"ws://127.0.0.1:3001","token":"StarBot"},{"enable":true,"type":"websocket","host":"ws://127.0.0.1:3002","token":"other"}]
# OVERFLOW_CONNECTIONS_JSON=

# 未设置 OVERFLOW_CONNECTIONS_JSON 时：仅渲染单条连接（环境变量如下）
OVERFLOW_CONNECTION_TYPE=websocket
OVERFLOW_CONNECTION_HOST=ws://127.0.0.1:3001
# OVERFLOW_CONNECTION_PORT=3002
OVERFLOW_CONNECTION_TOKEN=StarBot

# ===== 可选配置（使用默认值即可）=====
# 系统配置
# TZ=Asia/Shanghai
# JAVA_OPTS=-Xms512M -Xmx1G

# Overflow 其它项
# 更多说明见：https://github.com/MrXiaoM/Overflow/blob/main/docs/configuration.md
# OVERFLOW_NO_LOG=false
# OVERFLOW_NO_PLATFORM=false
# OVERFLOW_USE_CQ_CODE=false
# OVERFLOW_RETRY_TIMES=5
# OVERFLOW_RETRY_WAIT_MILLS=5000
# OVERFLOW_RETRY_REST_MILLS=60000
# OVERFLOW_HEARTBEAT_CHECK_SECONDS=60
# OVERFLOW_USE_GROUP_UPLOAD_EVENT=false
# OVERFLOW_RESOURCE_CACHE_ENABLED=false
# OVERFLOW_RESOURCE_CACHE_DURATION=168
# OVERFLOW_DROP_EVENTS_BEFORE_CONNECTED=true

# mirai-api-http
# MIRAI_HTTP_HOST=0.0.0.0
# MIRAI_HTTP_PORT=7827
# MIRAI_ENABLE_VERIFY=true
# MIRAI_VERIFY_KEY=StarBot

# ===== 系统配置（可选）=====
TZ=Asia/Shanghai
JAVA_OPTS=-Xms512M -Xmx1G
